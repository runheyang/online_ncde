# CUDA 12.8 + cuDNN + 开发工具（适合编译 3D 检测 CUDA 扩展）
FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    TZ=Etc/UTC

WORKDIR /workspace

# ---- 系统依赖：Python、编译、常见运行库（OpenCV/可视化会用到）----
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev \
    git curl wget ca-certificates \
    build-essential cmake ninja-build pkg-config \
    libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# python -> python3
RUN ln -sf /usr/bin/python3 /usr/bin/python && python -m pip install -U pip setuptools wheel

# ---- 固定 PyTorch 版本（你指定的）----
RUN pip install \
    torch==2.7.1 \
    torchvision==0.22.1 \
    torchaudio==2.7.1 \
    --index-url https://download.pytorch.org/whl/cu128

# ---- 额外构建依赖（spconv/cumm 编译用）----
    RUN apt-get update && apt-get install -y --no-install-recommends \
    libomp-dev \
    && rm -rf /var/lib/apt/lists/*

# ---- 编译相关环境变量：锁定 5090 = sm_120，避免编译全家桶 ----
ENV CUDA_HOME=/usr/local/cuda \
    CUMM_CUDA_ARCH_LIST="12.0" \
    TORCH_CUDA_ARCH_LIST="12.0" \
    MAX_JOBS=8 \
    CMAKE_BUILD_PARALLEL_LEVEL=8

# ---- Python 侧编译工具链（pccm 是 cumm/spconv 体系的基础）----
RUN pip install -U \
    ninja \
    pccm \
    pybind11 \
    packaging \
    cmake

# ---- 拉源码并锁定到 tag（不要用 main；官方明确建议用 tags）----
# spconv 最新版是 2.3.8（PyPI 上标的是 2024-12-15）:contentReference[oaicite:4]{index=4}
# cumm 近期常用是 0.8.2（示例），并且官方提示开发/构建尽量用 tags :contentReference[oaicite:5]{index=5}
ARG SPCONV_TAG=v2.3.8
ARG CUMM_TAG=v0.8.2

RUN git clone --depth=1 --branch ${CUMM_TAG} https://github.com/FindDefinition/cumm.git /opt/cumm \
 && pip install -e /opt/cumm --no-build-isolation

 RUN git clone --depth=1 --branch ${SPCONV_TAG} https://github.com/traveller59/spconv.git /opt/spconv \
 && sed -i 's/<0.8.0/<0.9.0/g' /opt/spconv/setup.py \
 && pip install -e /opt/spconv --no-build-isolation --no-deps

# ---- 触发完整的 JIT 编译（避免运行时第一次 import 才编译）----
RUN python -c "import os; \
    print('CUMM_CUDA_ARCH_LIST =', os.environ.get('CUMM_CUDA_ARCH_LIST')); \
    print('TORCH_CUDA_ARCH_LIST =', os.environ.get('TORCH_CUDA_ARCH_LIST')); \
    import cumm; \
    import spconv; \
    import spconv.pytorch as spconv_pytorch; \
    from spconv.pytorch import SparseConvTensor, SubMConv3d, SparseSequential; \
    print('cumm + spconv JIT compilation completed')"

# ---- 修改权限，让普通用户也能使用 ----
RUN chmod -R a+rwX /opt/cumm /opt/spconv

# ---- 数值/训练/可视化常用依赖（建议适度锁版本，保证可复现）----
# 注：numpy/scipy 在 ODE/数值稳定性上很关键，建议锁住
RUN pip install \
    numpy==1.26.4 \
    scipy==1.11.4 \
    pandas==2.3.3 \
    tqdm==4.67.1 \
    pyyaml==6.0.3 \
    tensorboard==2.20.0 \
    matplotlib==3.10.8 \
    opencv-python~=4.11.0 \
    einops \
    omegaconf \
    hydra-core \
    h5py \
    pyquaternion \
    scikit-learn \
    scikit-image \
    rich \
    seaborn \
    plotly \
    torchdiffeq==0.2.5 \
    open3d==0.18.0 \
    torchcde

# ========== OpenMMLab 栈（OPUS-V2 依赖）==========
# 1. mmengine（纯 Python，兼容性好）
RUN pip install "mmengine==0.10.6"

# 2. mmcv（源码编译 CUDA ops，固定 v2.1.0）
RUN git clone -b v2.1.0 https://github.com/open-mmlab/mmcv.git /opt/mmcv \
 && cd /opt/mmcv \
 && MMCV_WITH_OPS=1 FORCE_CUDA=1 python setup.py build_ext --inplace \
 && pip install -e .

# 3. mmdetection / mmsegmentation / mmdetection3d（直接指定版本）
RUN pip install \
    mmdet==3.3.0 \
    mmsegmentation==1.2.2 \
    mmdet3d==1.4.0

# 6. OPUS 特定依赖
RUN pip install \
    nuscenes-devkit \
    fvcore \
    prettytable \
    torch_scatter -f https://data.pyg.org/whl/torch-2.7.1+cu128.html

# 验证安装
RUN python -c "import mmengine, mmcv, mmdet, mmseg, mmdet3d, torch_scatter, fvcore, nuscenes; \
    print('OpenMMLab Stack Versions:'); \
    print('  mmengine:', mmengine.__version__); \
    print('  mmcv:', mmcv.__version__); \
    print('  mmdet:', mmdet.__version__); \
    print('  mmseg:', mmseg.__version__); \
    print('  mmdet3d:', mmdet3d.__version__); \
    print('  torch_scatter:', torch_scatter.__version__)"

# 修改 OpenMMLab 源码权限，让普通用户也能访问
RUN chmod -R a+rwX /opt/mmcv
# ---- 额外依赖：openmim + turbojpeg ----
RUN pip install openmim
RUN apt-get update && apt-get install -y --no-install-recommends \
    libjpeg-turbo8 libjpeg-turbo8-dev libturbojpeg0-dev \
    && rm -rf /var/lib/apt/lists/*
RUN pip install pyturbojpeg

# 更新动态链接器缓存
RUN ldconfig

# 安装 pillow-simd（优化版 Pillow）
RUN pip install pillow-simd==9.0.0.post1

RUN pip install wandb

# 建议增大共享内存（运行时用 --shm-size=16g）
CMD ["/bin/bash"]

